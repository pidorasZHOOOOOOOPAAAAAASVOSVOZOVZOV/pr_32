<Page x:Class="WpfApp1.Pages.Records.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Добавить пластинку">
    <Grid Background="#FFE6E6E6">
        <Border Background="White" Margin="20" CornerRadius="10">
            <StackPanel Margin="20">
                <TextBlock Text="Добавление пластинки" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                <Label Content="Название:"/>
                <TextBox x:Name="tbName" Margin="0,5,0,10" Height="35"/>

                <Label Content="Год выпуска:"/>
                <TextBox x:Name="tbYear" Margin="0,5,0,10" Height="35"/>

                <Label Content="Формат (0-Моно, 1-Стерео):"/>
                <ComboBox x:Name="cbFormat" Margin="0,5,0,10" Height="35">
                    <ComboBoxItem Content="Моно"/>
                    <ComboBoxItem Content="Стерео"/>
                </ComboBox>

                <Label Content="Размер:"/>
                <TextBox x:Name="tbSize" Margin="0,5,0,10" Height="35" Text="300"/>

                <Label Content="ID Производителя:"/>
                <TextBox x:Name="tbIdManufacturer" Margin="0,5,0,10" Height="35"/>

                <Label Content="Цена:"/>
                <TextBox x:Name="tbPrice" Margin="0,5,0,10" Height="35"/>

                <Label Content="ID Состояния:"/>
                <TextBox x:Name="tbIdState" Margin="0,5,0,10" Height="35"/>

                <Label Content="Описание:"/>
                <TextBox x:Name="tbDescription" Margin="0,5,0,10" Height="35"/>

                <Button Content="Сохранить" Click="Save_Click" Background="#FF9800" 
                        Foreground="White" FontWeight="Bold" Height="40" Margin="0,20,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>