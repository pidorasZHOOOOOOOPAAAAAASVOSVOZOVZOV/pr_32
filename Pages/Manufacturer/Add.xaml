<Page x:Class="PR_32.Pages.Manufacturer.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Добавить производителя">
    <Grid Background="#FFE6E6E6">
        <Border Background="#FFFAFAFA" Margin="20" CornerRadius="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="Black" ShadowDepth="5" Opacity="0.5"/>
            </Border.Effect>
            <Grid Margin="15">
                <StackPanel>
                    <TextBlock Text="Добавление производителя" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                    <Label Content="Название:"/>
                    <TextBox x:Name="tbName" Margin="0,5,0,10" Height="35" Padding="5"/>

                    <Label Content="Телефон:"/>
                    <TextBox x:Name="tbPhone" Margin="0,5,0,10" Height="35" Padding="5"/>

                    <Label Content="Email:"/>
                    <TextBox x:Name="tbEmail" Margin="0,5,0,10" Height="35" Padding="5"/>

                    <Button x:Name="btnSave" Content="Сохранить" Click="BtnSave_Click" 
                            Background="#FF9800" Foreground="White" FontWeight="Bold"
                            Margin="0,20,0,0" Height="40" FontSize="14"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>