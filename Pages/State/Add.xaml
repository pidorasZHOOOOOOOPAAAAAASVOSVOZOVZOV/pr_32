<Page x:Class="WpfApp1.Pages.State.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Добавить состояние">
    <Grid Background="#FFE6E6E6">
        <Border Background="White" Margin="20" CornerRadius="10">
            <StackPanel Margin="20">
                <TextBlock Text="Добавление состояния" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                <Label Content="Название:"/>
                <TextBox x:Name="tbName" Margin="0,5,0,10" Height="35"/>

                <Label Content="Код (Subname):"/>
                <TextBox x:Name="tbSubname" Margin="0,5,0,10" Height="35"/>

                <Label Content="Описание:"/>
                <TextBox x:Name="tbDescription" Margin="0,5,0,10" Height="100" TextWrapping="Wrap"/>

                <Button Content="Сохранить" Click="Save_Click" Background="#FF9800" 
                        Foreground="White" FontWeight="Bold" Height="40" Margin="0,20,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>