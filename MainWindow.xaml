<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VinylRecords - Учет виниловых пластинок" 
        Height="600" Width="1000">
    <Grid>
        <Menu Height="25" VerticalAlignment="Top">
            <MenuItem Header="Пластинки">
                <MenuItem Header="Список" Click="OpenRecordList"/>
                <MenuItem Header="Добавить" Click="OpenRecordAdd"/>
                <MenuItem Header="Экспортировать" Click="ExportRecord"/>
            </MenuItem>
            <MenuItem Header="Производители">
                <MenuItem Header="Список" Click="OpenManufacturesList"/>
                <MenuItem Header="Добавить" Click="OpenManufacturesAdd"/>
            </MenuItem>
            <MenuItem Header="Поставки">
                <MenuItem Header="Список" Click="OpenSupplyList"/>
                <MenuItem Header="Добавить" Click="OpenSupplyAdd"/>
            </MenuItem>
            <MenuItem Header="Состояния">
                <MenuItem Header="Список" Click="OpenStateList"/>
                <MenuItem Header="Добавить" Click="OpenStateAdd"/>
            </MenuItem>
        </Menu>
        <Frame x:Name="frame" NavigationUIVisibility="Hidden" Margin="0,25,0,0"/>
    </Grid>
</Window>